#!/bin/sh
set -e

if ! command -v npm >/dev/null 2>&1; then
  echo "pre-commit: npm is required but was not found on PATH." >&2
  exit 1
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "pre-commit: cargo is required but was not found on PATH." >&2
  exit 1
fi

npm run check
npm run check:rust
npm run format:check
npm run format:check:rust
